# PostgreSQL o Prisma Accelerate (Vercel Postgres, Neon, Supabase, etc.)
# Ejemplo directo: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Opcional: si DATABASE_URL es prisma+postgres:// (Accelerate) y en local aparece P5010 / "fetch failed",
# pegue aquí la URL postgresql:// del mismo origen. La app la usará en runtime y en db:seed.
# DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth — Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Secreto para cookies de sesión (ej.: openssl rand -base64 32). Alias aceptado: AUTH_SECRET
NEXTAUTH_SECRET=""
# URL base del sitio, sin barra final (ej. http://localhost:3000). Alias aceptado: AUTH_URL
NEXTAUTH_URL="http://localhost:3000"
